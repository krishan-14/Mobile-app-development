        <item name="colorPrimary">#1565C0</item>       <!-- Blue -->
        <item name="colorPrimaryVariant">#003c8f</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#E8950A</item>     <!-- Amber accent -->
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:statusBarColor">#1565C0</item>
    </style>
</resources>
