<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_image_detail.xml — Image details screen.

    Structure:
      ScrollView
        LinearLayout (vertical)
          ImageView         (full image preview, 250dp tall)
          CardView          (metadata table: name / path / size / date)
          Button            (Delete — red)
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Image preview ──────────────────────────────────── -->
        <ImageView
            android:id="@+id/ivDetail"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:scaleType="fitCenter"
            android:background="#607D8B"
            android:contentDescription="Selected image" />

        <!-- ── Metadata card ──────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Name row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Name"
                        android:textSize="13sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textSize="13sp"
                        android:textColor="#111111"
                        android:textStyle="bold"
                        android:gravity="end" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="#EEEEEE" android:layout_marginBottom="12dp"/>

                <!-- Path row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Path"
                        android:textSize="13sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/tvPath"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textSize="12sp"
                        android:textColor="#111111"
                        android:gravity="end" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="#EEEEEE" android:layout_marginBottom="12dp"/>

                <!-- Size row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Size"
                        android:textSize="13sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/tvSize"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textSize="13sp"
                        android:textColor="#111111"
                        android:textStyle="bold"
                        android:gravity="end" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="#EEEEEE" android:layout_marginBottom="12dp"/>

                <!-- Date taken row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Date taken"
                        android:textSize="13sp"
                        android:textColor="#888888" />

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textSize="13sp"
                        android:textColor="#111111"
                        android:textStyle="bold"
                        android:gravity="end" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Delete button ──────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFEBEE">

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🗑  Delete Image"
                android:textSize="15sp"
                android:textColor="#C62828"
                android:textStyle="bold"
                android:background="@android:color/transparent"
                android:gravity="center" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>