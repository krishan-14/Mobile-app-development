<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — Home screen layout.

    Structure:
      ScrollView
        LinearLayout (vertical)
          TextView  (app title / subtitle)
          CardView  (Take Photo)
          CardView  (Choose Folder)
          TextView  (recent photos label)
          RecyclerView (small preview – optional; can be removed)
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Header ─────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Photo Gallery"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Take photos or browse a folder"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="24dp" />

        <!-- ── Take Photo card ────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#1565C0">

            <!-- Button fills the whole card -->
            <Button
                android:id="@+id/btnTakePhoto"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:text="📷  Take Photo"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@android:color/transparent"
                android:gravity="center" />

        </androidx.cardview.widget.CardView>

        <!-- ── Choose Folder card ─────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <Button
                android:id="@+id/btnChooseFolder"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:text="📁  Choose Folder"
                android:textSize="16sp"
                android:textColor="#1565C0"
                android:textStyle="bold"
                android:background="@android:color/transparent"
                android:gravity="center" />

        </androidx.cardview.widget.CardView>

        <!-- ── Info text at bottom ────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Photos are saved to:\n/Pictures/ in app storage"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:lineSpacingExtra="4dp"
            android:layout_gravity="center_horizontal" />

    </LinearLayout>
</ScrollView>