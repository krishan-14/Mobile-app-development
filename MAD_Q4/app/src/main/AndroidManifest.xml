<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.photogallery">

    <!-- Permissions for camera -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Storage permissions (for Android < 13) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!-- Storage permissions (for Android 13+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <uses-feature android:name="android.hardware.camera" android:required="true" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Photo Gallery"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PhotoGallery">

        <!-- MainActivity: Home screen -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- GalleryActivity: Grid view of images in a folder -->
        <activity android:name=".GalleryActivity" android:exported="false" />

        <!-- ImageDetailActivity: Details + delete for a single image -->
        <activity android:name=".ImageDetailActivity" android:exported="false" />

        <!-- FileProvider: required to share camera file URI on Android 7+ -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.photogallery.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>